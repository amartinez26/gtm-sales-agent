# ── Required ──────────────────────────────────────────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Must match the key used in config.py — default is "answer", change if needed
PITCH_KEY=answer

# ── Document Ingestion ────────────────────────────────────────────────────────
# Path to the folder smart_ingest.py and watchdog_service.py will monitor.
# Can be a local folder or a UNC path to an SMB share (e.g. \\server\share\docs)
WATCH_PATH=./data/stihl_intelligence
